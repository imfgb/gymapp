# Copy this file to `.env` and fill the values. NEVER commit `.env`.
#
# Generate a dev SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# Which settings module to use:
#   - config.settings.dev   (local development)
#   - config.settings.prod  (Railway / production)
#   - config.settings.test  (test runner)
DJANGO_SETTINGS_MODULE=config.settings.dev

# Required. Any string for dev; Railway sets a strong one in prod.
DJANGO_SECRET_KEY=

# Debug must be `false` in prod. Default in code is false.
DJANGO_DEBUG=true

# Comma-separated. Use `*` only for quick local probing, never in prod.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection string. The local docker-compose service exposes this.
DATABASE_URL=postgres://gymapp:gymapp@localhost:5432/gymapp

# Sentry (prod only). Leave empty in dev — Sentry is disabled when unset.
SENTRY_DSN=

# Bearer token for the feedback triage API (admin automation). Empty = API
# disabled. Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the SAME value on Railway and in your local .env. NEVER commit the real value.
FEEDBACK_API_TOKEN=

# Production base URL — used locally by the triage skills to reach the prod API.
PROD_BASE_URL=https://gymapp-production-1029.up.railway.app

# Localization. Fixed for the project; here for visibility.
TIME_ZONE=America/Mexico_City
LANGUAGE_CODE=es-mx
